{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check:encoding": "node ./scripts/check-encoding.mjs",
    "build": "vue-tsc -b && node ./scripts/vite-build.mjs",
    "preview": "vite preview",
    "test:e2e": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-playwright.ps1 test",
    "smoke:login": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-playwright.ps1 test tests/login-smoke.spec.ts --project=chromium",
    "smoke:login:headed": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-playwright.ps1 test tests/login-smoke.spec.ts --project=chromium --headed",
    "smoke": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"npm.cmd run smoke:settings; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; npm.cmd run smoke:business; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; npm.cmd run smoke:ai; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; npm.cmd run smoke:cases; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; npm.cmd run smoke:tasks; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; npm.cmd run smoke:reports\"",
    "smoke:headed": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"npm.cmd run smoke:settings:headed; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; npm.cmd run smoke:business:headed; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-playwright.ps1 test tests/ai-smoke.spec.ts tests/ai-candidates-smoke.spec.ts --project=chromium --headed --workers=1; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; npm.cmd run smoke:cases:headed; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; npm.cmd run smoke:tasks:headed; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; npm.cmd run smoke:reports:headed\"",
    "smoke:settings": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-playwright.ps1 test tests/settings-smoke.spec.ts --project=chromium",
    "smoke:business": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-playwright.ps1 test tests/business-smoke.spec.ts --project=chromium",
    "smoke:ai": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-playwright.ps1 test tests/ai-smoke.spec.ts tests/ai-candidates-smoke.spec.ts --project=chromium --workers=1",
    "smoke:cases": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-playwright.ps1 test tests/cases-crud-smoke.spec.ts --project=chromium",
    "smoke:tasks": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-playwright.ps1 test tests/tasks-crud-smoke.spec.ts --project=chromium",
    "smoke:reports": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-playwright.ps1 test tests/reports-crud-smoke.spec.ts --project=chromium",
    "smoke:mysql": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-mysql-smoke.ps1 -Suite smoke",
    "smoke:mysql:cases": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-mysql-smoke.ps1 -Suite smoke:cases",
    "smoke:mysql:tasks": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-mysql-smoke.ps1 -Suite smoke:tasks",
    "smoke:mysql:reports": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-mysql-smoke.ps1 -Suite smoke:reports",
    "smoke:mysql:crud": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"cd .; npm.cmd run smoke:mysql:cases; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; npm.cmd run smoke:mysql:tasks; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; npm.cmd run smoke:mysql:reports\"",
    "smoke:business:headed": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-playwright.ps1 test tests/business-smoke.spec.ts --project=chromium --headed",
    "smoke:cases:headed": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-playwright.ps1 test tests/cases-crud-smoke.spec.ts --project=chromium --headed",
    "smoke:tasks:headed": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-playwright.ps1 test tests/tasks-crud-smoke.spec.ts --project=chromium --headed",
    "smoke:reports:headed": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-playwright.ps1 test tests/reports-crud-smoke.spec.ts --project=chromium --headed",
    "smoke:settings:headed": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-playwright.ps1 test tests/settings-smoke.spec.ts --project=chromium --headed",
    "e2e:install": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-playwright.ps1 install chromium"
  },
  "dependencies": {
    "@tiptap/extension-highlight": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-task-item": "^3.22.3",
    "@tiptap/extension-task-list": "^3.22.3",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-text-style": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@tiptap/vue-3": "^3.22.3",
    "@element-plus/icons-vue": "^2.3.2",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.7",
    "pinia": "^3.0.4",
    "sass": "^1.99.0",
    "vue": "^3.5.32",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7"
  }
}
